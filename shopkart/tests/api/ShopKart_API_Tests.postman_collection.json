{
  "info": {
    "name": "ShopKart API Tests",
    "description": "Complete API test collection for ShopKart - SDET Practice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', body.token);",
                  "});",
                  "pm.test('Has user fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.name).to.exist;",
                  "  pm.expect(body.email).to.exist;",
                  "  pm.expect(body.password).to.not.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@shopkart.com\",\n  \"password\": \"test123\"\n}"
            }
          }
        },
        {
          "name": "Register User - Missing Fields",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 for missing fields', () => pm.response.to.have.status(400));",
                  "pm.test('Has error message', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"incomplete@test.com\"\n}"
            }
          }
        },
        {
          "name": "Register - Short Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 for short password', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"short@test.com\",\n  \"password\": \"abc\"\n}"
            }
          }
        },
        {
          "name": "Login - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns token', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', body.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@shopkart.com\",\n  \"password\": \"test123\"\n}"
            }
          }
        },
        {
          "name": "Login - Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401 for wrong password', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@shopkart.com\",\n  \"password\": \"wrongpass\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Seed Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Products seeded', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.products).to.be.an('array');",
                  "  pm.expect(body.products.length).to.be.greaterThan(0);",
                  "  if (body.products.length > 0) {",
                  "    pm.collectionVariables.set('product_id', body.products[0]._id);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/products/seed"
          }
        },
        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => {",
                  "  pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Products have required fields', () => {",
                  "  const products = pm.response.json();",
                  "  if (products.length > 0) {",
                  "    pm.expect(products[0]).to.have.property('name');",
                  "    pm.expect(products[0]).to.have.property('price');",
                  "    pm.expect(products[0]).to.have.property('category');",
                  "  }",
                  "});",
                  "pm.test('Price is a positive number', () => {",
                  "  const products = pm.response.json();",
                  "  products.forEach(p => pm.expect(p.price).to.be.above(0));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Get Products by Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('All results are Electronics', () => {",
                  "  const products = pm.response.json();",
                  "  products.forEach(p => pm.expect(p.category).to.equal('Electronics'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products?category=Electronics",
              "query": [{ "key": "category", "value": "Electronics" }]
            }
          }
        },
        {
          "name": "Get Single Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has _id', () => pm.expect(pm.response.json()._id).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/{{product_id}}"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart - Authenticated",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Cart - No Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401 without token', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cart"
          }
        },
        {
          "name": "Add to Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Item added to cart', () => {",
                  "  const cart = pm.response.json();",
                  "  pm.expect(cart).to.be.an('array');",
                  "  pm.expect(cart.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/cart/add",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{product_id}}\",\n  \"name\": \"Test Product\",\n  \"price\": 999,\n  \"quantity\": 1\n}"
            }
          }
        }
      ]
    }
  ]
}
